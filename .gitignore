# Generated winget package manifests at the repo root only.
# Anchored with a leading slash so it does NOT match source folders such as
# src/WingetMaintainer.Core/Manifests/ (git is case-insensitive on Windows/macOS).
/manifests/
scripts/package-cleanup/broken_packages.csv
scripts/package-cleanup/cleaned_packages.csv
*.msi
*.exe
*.zip
*.appx
*.msix
*.msixbundle

# .NET build output / IDE
bin/
obj/
.vs/
*.user
artifacts/
publish/
TestResults/
*.trx

# Local SQLite databases
*.db
*.db-shm
*.db-wal

# Observability stack local secrets/logs
docker/.env
docker/sandbox-logs/
