<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Clear any machine/user-level feeds so restore is deterministic and works
       with Central Package Management (single source). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
