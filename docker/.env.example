# Example environment for the stack. Copy to .env and fill in secrets.
# NEVER commit the real .env (see .gitignore).

# Worker (Cronos scheduler + internal API) container
# API key required on every /api/* request (X-Api-Key header). No default — must be set.
WORKER_API_KEY=change-me
# Cron for the scheduled catalog check (default hourly).
WORKER_SCHEDULE_CRON=0 * * * *
# Enable real PR submission (legacy SUBMIT_PR equivalent). Keep false during shadow mode.
WORKER_SUBMIT_ENABLED=false
# Failed-validation threshold before a package is skipped (decision D14).
WORKER_MAX_FAILURES=3

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_ROOT_URL=http://localhost:3000

# Loki push endpoint used by Alloy (and by the .NET apps' Serilog Loki sink)
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push
LOKI_USERNAME=
LOKI_PASSWORD=

# Deployment environment label value
WINGET_ENVIRONMENT=Production

# Where the sandbox validation logs live on the host (mounted read-only into Alloy)
SANDBOX_LOG_DIR=./sandbox-logs
SANDBOX_LOG_GLOB=/sandbox-logs/*.log

# ntfy contact point for Grafana alerts (D10)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
