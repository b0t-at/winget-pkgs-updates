# Example environment for the observability stack. Copy to .env and fill in secrets.
# NEVER commit the real .env (see .gitignore).

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_ROOT_URL=http://localhost:3000

# Loki push endpoint used by Alloy (and by the .NET apps' Serilog Loki sink)
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push
LOKI_USERNAME=
LOKI_PASSWORD=

# Deployment environment label value
WINGET_ENVIRONMENT=Production

# Where the sandbox validation logs live on the host (mounted read-only into Alloy)
SANDBOX_LOG_DIR=./sandbox-logs
SANDBOX_LOG_GLOB=/sandbox-logs/*.log

# ntfy contact point for Grafana alerts (D10)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
