{
  "uid": "wm-pipeline-overview",
  "title": "Pipeline Overview",
  "tags": ["winget-maintainer"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "query": "Production,Test",
        "current": { "text": "Production", "value": "Production" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Packages processed (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"winget-maintainer\", environment=\"$environment\"} | json | event=\"package_result\" [24h]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failures (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"winget-maintainer\", environment=\"$environment\"} | json | event=\"package_result\" | outcome=\"failed\" [24h]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Submitted PRs (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"winget-maintainer\", environment=\"$environment\", phase=\"submit\"} | json | event=\"pr_submitted\" [24h]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Results by phase",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (phase) (count_over_time({app=\"winget-maintainer\", environment=\"$environment\"} | json | event=\"package_result\" [$__interval]))",
          "legendFormat": "{{phase}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent activity",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "expr": "{app=\"winget-maintainer\", environment=\"$environment\"} | json" }
      ]
    }
  ]
}
