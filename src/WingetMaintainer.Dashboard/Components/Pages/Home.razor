@page "/"
@using WingetMaintainer.Dashboard.Models
@using WingetMaintainer.Dashboard.Services
@inject WorkerClient Worker
@rendermode InteractiveServer

<PageTitle>Overview</PageTitle>

<h1>Pipeline Overview</h1>

@if (loadError is not null)
{
    <p class="wm-error">Could not reach the Worker API: @loadError</p>
}
else if (runs is null)
{
    <p>Loading…</p>
}
else
{
    <p>@runs.Count recent run(s).</p>
    <table class="wm-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Package</th>
                <th>Version</th>
                <th>Phase</th>
                <th>Outcome</th>
                <th>Started</th>
            </tr>
        </thead>
        <tbody>
            @foreach (RunDto run in runs)
            {
                <tr>
                    <td>@run.Id</td>
                    <td>@run.PackageIdentifier</td>
                    <td>@run.Version</td>
                    <td>@run.Phase</td>
                    <td>@run.Outcome</td>
                    <td>@run.StartedAt.ToString("u")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<RunDto>? runs;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            runs = await Worker.GetRunsAsync(CancellationToken.None);
        }
        catch (Exception exception)
        {
            loadError = exception.Message;
        }
    }
}
